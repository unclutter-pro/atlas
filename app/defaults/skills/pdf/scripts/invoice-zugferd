#!/usr/bin/env python3
"""invoice-zugferd — embed a ZUGFeRD/Factur-X XML into a rendered invoice PDF.

Produces an EU-conform e-invoice (EN 16931) by:
  1. Reading the JSON used to render the PDF (same shape as templates/invoice.typ expects).
  2. Generating a CII (Cross-Industry Invoice) XML for the EN 16931 standard.
  3. Embedding the XML as a Factur-X attachment into the PDF (PDF/A-3 compliant).

Usage:
    invoice-zugferd <invoice.pdf> <invoice.json> [output.pdf]

If output.pdf is omitted, writes alongside the input as <invoice>_factur-x.pdf.

Conformance level: EN 16931 (Factur-X "EN 16931" profile / ZUGFeRD 2.x "EN 16931"). This is
the EU baseline that German B2B partners and public sector buyers accept since 2025.

Profiles supported (--profile flag):
  - MINIMUM      — buyer + seller + totals only (rarely useful)
  - BASIC WL     — without lines (totals + tax breakdown)
  - BASIC        — totals + line items
  - EN 16931     — DEFAULT, full EU baseline
  - EXTENDED     — EN 16931 + extended fields (delivery refs etc.)

Dependencies (installed by the Atlas Dockerfile):
  - facturx (pip)
  - lxml (pip)
"""
from __future__ import annotations

import argparse
import json
import os
import sys
from datetime import datetime
from decimal import Decimal
from xml.sax.saxutils import escape as xml_escape


def _money(n: float) -> str:
    """Two-decimal string for EN 16931 monetary fields (point separator)."""
    return f"{Decimal(str(n)).quantize(Decimal('0.01'))}"


def _format_date(d: str) -> str:
    """Convert YYYY-MM-DD or YYYY-MM-DD — YYYY-MM-DD to YYYYMMDD (EN 16931 format 102)."""
    # Take the first ISO date in the string
    s = d.split(" — ")[0].split(" - ")[0].strip()
    try:
        return datetime.fromisoformat(s).strftime("%Y%m%d")
    except ValueError:
        return s.replace("-", "")


def build_cii_xml(data: dict, profile: str = "EN 16931") -> bytes:
    """Build a minimal valid CII XML (EN 16931 conform) from invoice JSON.

    This is intentionally hand-rolled rather than a heavy framework — keeps the
    Atlas image lean. For more advanced fields (multiple tax rates, payment
    references, etc.) extend the elements below.
    """
    is_klein = data.get("kleinunternehmer", False)
    vat_rate = Decimal("0.00") if is_klein else Decimal(str(data.get("vat_rate", 0.19)))
    items = data["items"]
    subtotal = sum(Decimal(str(it["qty"])) * Decimal(str(it["unit_price"])) for it in items)
    vat_amount = subtotal * vat_rate
    total = subtotal + vat_amount

    invoice_date = _format_date(data["date"])
    due_date = _format_date(data["due_date"])
    service_date = _format_date(data.get("service_date", data["date"]))

    currency = data.get("currency", "EUR")
    inv_no = data["invoice_no"]

    seller = data["from"]
    buyer = data["to"]

    e = xml_escape

    # CII headers and required wrappers
    lines_xml = "".join(_render_line(i + 1, it, currency, vat_rate, is_klein)
                        for i, it in enumerate(items))

    xml = f"""<?xml version="1.0" encoding="UTF-8"?>
<rsm:CrossIndustryInvoice
    xmlns:rsm="urn:un:unece:uncefact:data:standard:CrossIndustryInvoice:100"
    xmlns:ram="urn:un:unece:uncefact:data:standard:ReusableAggregateBusinessInformationEntity:100"
    xmlns:udt="urn:un:unece:uncefact:data:standard:UnqualifiedDataType:100">
  <rsm:ExchangedDocumentContext>
    <ram:GuidelineSpecifiedDocumentContextParameter>
      <ram:ID>urn:cen.eu:en16931:2017</ram:ID>
    </ram:GuidelineSpecifiedDocumentContextParameter>
  </rsm:ExchangedDocumentContext>
  <rsm:ExchangedDocument>
    <ram:ID>{e(inv_no)}</ram:ID>
    <ram:TypeCode>380</ram:TypeCode>
    <ram:IssueDateTime>
      <udt:DateTimeString format="102">{invoice_date}</udt:DateTimeString>
    </ram:IssueDateTime>
  </rsm:ExchangedDocument>
  <rsm:SupplyChainTradeTransaction>
{lines_xml}
    <ram:ApplicableHeaderTradeAgreement>
      <ram:SellerTradeParty>
        <ram:Name>{e(seller["name"])}</ram:Name>
        <ram:PostalTradeAddress>
          <ram:PostcodeCode>{e(seller["address2"].split()[0] if seller.get("address2") else "")}</ram:PostcodeCode>
          <ram:LineOne>{e(seller["address1"])}</ram:LineOne>
          <ram:CityName>{e(" ".join(seller["address2"].split()[1:]) if seller.get("address2") else "")}</ram:CityName>
          <ram:CountryID>DE</ram:CountryID>
        </ram:PostalTradeAddress>
        {f'<ram:SpecifiedTaxRegistration><ram:ID schemeID="VA">{e(seller["tax_id"])}</ram:ID></ram:SpecifiedTaxRegistration>' if seller.get("tax_id") else ""}
      </ram:SellerTradeParty>
      <ram:BuyerTradeParty>
        <ram:Name>{e(buyer["name"])}</ram:Name>
        <ram:PostalTradeAddress>
          <ram:PostcodeCode>{e(buyer["address2"].split()[0] if buyer.get("address2") else "")}</ram:PostcodeCode>
          <ram:LineOne>{e(buyer["address1"])}</ram:LineOne>
          <ram:CityName>{e(" ".join(buyer["address2"].split()[1:]) if buyer.get("address2") else "")}</ram:CityName>
          <ram:CountryID>DE</ram:CountryID>
        </ram:PostalTradeAddress>
        {f'<ram:SpecifiedTaxRegistration><ram:ID schemeID="VA">{e(buyer["tax_id"])}</ram:ID></ram:SpecifiedTaxRegistration>' if buyer.get("tax_id") else ""}
      </ram:BuyerTradeParty>
    </ram:ApplicableHeaderTradeAgreement>
    <ram:ApplicableHeaderTradeDelivery>
      <ram:ActualDeliverySupplyChainEvent>
        <ram:OccurrenceDateTime>
          <udt:DateTimeString format="102">{service_date}</udt:DateTimeString>
        </ram:OccurrenceDateTime>
      </ram:ActualDeliverySupplyChainEvent>
    </ram:ApplicableHeaderTradeDelivery>
    <ram:ApplicableHeaderTradeSettlement>
      <ram:InvoiceCurrencyCode>{currency}</ram:InvoiceCurrencyCode>
      <ram:ApplicableTradeTax>
        <ram:CalculatedAmount>{_money(vat_amount)}</ram:CalculatedAmount>
        <ram:TypeCode>VAT</ram:TypeCode>
        {('<ram:ExemptionReason>Kleinunternehmer §19 UStG</ram:ExemptionReason>' if is_klein else '')}
        <ram:BasisAmount>{_money(subtotal)}</ram:BasisAmount>
        <ram:CategoryCode>{'E' if is_klein else 'S'}</ram:CategoryCode>
        <ram:RateApplicablePercent>{_money(vat_rate * 100)}</ram:RateApplicablePercent>
      </ram:ApplicableTradeTax>
      <ram:SpecifiedTradePaymentTerms>
        <ram:DueDateDateTime>
          <udt:DateTimeString format="102">{due_date}</udt:DateTimeString>
        </ram:DueDateDateTime>
      </ram:SpecifiedTradePaymentTerms>
      <ram:SpecifiedTradeSettlementHeaderMonetarySummation>
        <ram:LineTotalAmount>{_money(subtotal)}</ram:LineTotalAmount>
        <ram:TaxBasisTotalAmount>{_money(subtotal)}</ram:TaxBasisTotalAmount>
        <ram:TaxTotalAmount currencyID="{currency}">{_money(vat_amount)}</ram:TaxTotalAmount>
        <ram:GrandTotalAmount>{_money(total)}</ram:GrandTotalAmount>
        <ram:DuePayableAmount>{_money(total)}</ram:DuePayableAmount>
      </ram:SpecifiedTradeSettlementHeaderMonetarySummation>
    </ram:ApplicableHeaderTradeSettlement>
  </rsm:SupplyChainTradeTransaction>
</rsm:CrossIndustryInvoice>
"""
    return xml.encode("utf-8")


def _render_line(idx: int, item: dict, currency: str, vat_rate: Decimal, is_klein: bool) -> str:
    e = xml_escape
    qty = Decimal(str(item["qty"]))
    unit_price = Decimal(str(item["unit_price"]))
    line_total = qty * unit_price
    return f"""    <ram:IncludedSupplyChainTradeLineItem>
      <ram:AssociatedDocumentLineDocument>
        <ram:LineID>{idx}</ram:LineID>
      </ram:AssociatedDocumentLineDocument>
      <ram:SpecifiedTradeProduct>
        <ram:Name>{e(item['description'])}</ram:Name>
      </ram:SpecifiedTradeProduct>
      <ram:SpecifiedLineTradeAgreement>
        <ram:NetPriceProductTradePrice>
          <ram:ChargeAmount>{_money(unit_price)}</ram:ChargeAmount>
        </ram:NetPriceProductTradePrice>
      </ram:SpecifiedLineTradeAgreement>
      <ram:SpecifiedLineTradeDelivery>
        <ram:BilledQuantity unitCode="C62">{_money(qty)}</ram:BilledQuantity>
      </ram:SpecifiedLineTradeDelivery>
      <ram:SpecifiedLineTradeSettlement>
        <ram:ApplicableTradeTax>
          <ram:TypeCode>VAT</ram:TypeCode>
          <ram:CategoryCode>{'E' if is_klein else 'S'}</ram:CategoryCode>
          <ram:RateApplicablePercent>{_money(vat_rate * 100)}</ram:RateApplicablePercent>
        </ram:ApplicableTradeTax>
        <ram:SpecifiedTradeSettlementLineMonetarySummation>
          <ram:LineTotalAmount>{_money(line_total)}</ram:LineTotalAmount>
        </ram:SpecifiedTradeSettlementLineMonetarySummation>
      </ram:SpecifiedLineTradeSettlement>
    </ram:IncludedSupplyChainTradeLineItem>
"""


def embed_xml(input_pdf: str, output_pdf: str, xml_bytes: bytes) -> None:
    """Embed the CII XML into the PDF as a Factur-X attachment."""
    try:
        from facturx import generate_from_file
    except ImportError as exc:
        sys.stderr.write(
            "error: facturx Python module not available — install with "
            "`pip install --break-system-packages factur-x` first.\n"
        )
        raise SystemExit(1) from exc

    # facturx's generate_from_file mutates the PDF in place (or writes the output_pdf path).
    # API: generate_from_file(pdf_file, xml=None, ... output_pdf_file=...)
    generate_from_file(
        input_pdf,
        xml=xml_bytes,
        check_xsd=False,  # We're not shipping the XSD here; trust the schema we generate.
        output_pdf_file=output_pdf,
        pdf_metadata={
            "author": "",
            "keywords": "",
            "title": "",
            "subject": "",
        },
    )


def main() -> int:
    p = argparse.ArgumentParser(
        prog="invoice-zugferd",
        description="Embed a ZUGFeRD/Factur-X XML into a rendered invoice PDF.",
    )
    p.add_argument("input_pdf", help="The PDF rendered by build-pdf invoice")
    p.add_argument("input_json", help="The invoice JSON used to render the PDF")
    p.add_argument("output_pdf", nargs="?", help="Output path (default: <input>_factur-x.pdf)")
    p.add_argument("--profile", default="EN 16931",
                   help="ZUGFeRD profile (MINIMUM, BASIC WL, BASIC, EN 16931, EXTENDED). Default: EN 16931")
    args = p.parse_args()

    if not os.path.exists(args.input_pdf):
        sys.stderr.write(f"error: PDF not found: {args.input_pdf}\n")
        return 1
    if not os.path.exists(args.input_json):
        sys.stderr.write(f"error: JSON not found: {args.input_json}\n")
        return 1

    with open(args.input_json, encoding="utf-8") as fh:
        data = json.load(fh)

    output_pdf = args.output_pdf or args.input_pdf.replace(".pdf", "_factur-x.pdf")

    xml_bytes = build_cii_xml(data, profile=args.profile)
    embed_xml(args.input_pdf, output_pdf, xml_bytes)

    print(f"✓ {output_pdf}")
    print(f"  profile: {args.profile}")
    print(f"  XML embedded: factur-x.xml ({len(xml_bytes)} bytes)")
    return 0


if __name__ == "__main__":
    sys.exit(main())
