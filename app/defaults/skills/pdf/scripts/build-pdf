#!/usr/bin/env bash
# build-pdf — wrapper around `typst compile` that uses the bundled templates and JSON inputs.
#
# Usage:
#   build-pdf <template> [options] <output.pdf>
#   build-pdf report    --title "Marktrecherche" --subtitle "DACH" --author "Atlas"  out/report.pdf
#   build-pdf invoice   --data path/to/invoice.json                                    out/invoice.pdf
#   build-pdf letter    --data path/to/letter.json                                     out/letter.pdf
#   build-pdf memo      --title "Sprint Recap" --to "Team" --from "Max"                out/memo.pdf
#
# Bundled templates: report | invoice | letter | memo
# Custom .typ files: build-pdf path/to/file.typ output.pdf
#
# Set --root to the template's parent dir so it can read images/charts/json sitting next to it.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SKILL_DIR="$(dirname "$SCRIPT_DIR")"

if [ $# -lt 2 ]; then
  cat >&2 <<'EOF'
Usage: build-pdf <template-or-path> [--key value ...] <output.pdf>

Templates bundled in the skill:
  report   --title "..." --subtitle "..." --author "..." --date "..."
  invoice  --data path/to/invoice.json
  letter   --data path/to/letter.json
  memo     --title "..." --to "..." --from "..." --date "..."

Custom: pass a path to any .typ file as the first argument.
EOF
  exit 1
fi

TEMPLATE_ARG="$1"; shift

# Resolve template path
case "$TEMPLATE_ARG" in
  report|invoice|letter|memo)
    TEMPLATE="$SKILL_DIR/templates/${TEMPLATE_ARG}.typ"
    ;;
  *.typ)
    TEMPLATE="$TEMPLATE_ARG"
    ;;
  *)
    echo "error: unknown template '$TEMPLATE_ARG' — must be report|invoice|letter|memo or *.typ" >&2
    exit 1
    ;;
esac

if [ ! -f "$TEMPLATE" ]; then
  echo "error: template not found: $TEMPLATE" >&2
  exit 1
fi

# Collect --key value pairs as --input flags, last positional is the output path
INPUTS=()
OUTPUT=""
while [ $# -gt 0 ]; do
  case "$1" in
    --*=*)
      INPUTS+=("--input" "${1#--}")
      shift
      ;;
    --*)
      KEY="${1#--}"
      VALUE="${2:-}"
      INPUTS+=("--input" "${KEY}=${VALUE}")
      shift 2
      ;;
    *)
      OUTPUT="$1"
      shift
      ;;
  esac
done

if [ -z "$OUTPUT" ]; then
  echo "error: missing output PDF path" >&2
  exit 1
fi

mkdir -p "$(dirname "$OUTPUT")"

# --root must cover both the template dir AND the working dir (for chart PNGs etc.)
typst compile \
  --root "$(pwd)" \
  "${INPUTS[@]}" \
  "$TEMPLATE" \
  "$OUTPUT"

echo "✓ $OUTPUT"
